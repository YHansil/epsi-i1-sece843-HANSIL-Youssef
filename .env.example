# ============================================
# SecuByDesign - Variables d'environnement
# ============================================
# Copiez ce fichier en .env avant de lancer le projet :
#   cp .env.example .env
#
# Vous pouvez modifier les valeurs ci-dessous
# selon vos besoins. L'application elle-même
# récupère ses secrets depuis HashiCorp Vault.
# ============================================

# Vault
VAULT_TOKEN=changeme-vault-token

# MariaDB (initialisation du conteneur uniquement)
DB_ROOT_PASSWORD=changeme-root-password
DB_NAME=secubydesign
DB_USER=secuby
DB_PASSWORD=changeme-StrongP@ss20chars!!

# Application secrets (injectés dans Vault)
APP_PEPPER=changeme-random-pepper-32chars!!
APP_SECRET_KEY=changeme-flask-secret-key-here!
