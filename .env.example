# ============================================
# SecuByDesign - Variables d'environnement
# ============================================
# Copiez ce fichier en .env avant de lancer le projet :
#   cp .env.example .env
#
# Seul le token Vault est configuré ici.
# Tous les autres secrets (credentials DB, poivre,
# clé de session) sont gérés dans init_vault.sh
# et injectés directement dans HashiCorp Vault.
# ============================================

# Vault (token root du mode développement)
VAULT_TOKEN=changeme-vault-token
